{% extends 'base.html.twig' %}

{% block title %}Hors ligne - {{ app_name|default('MonApp') }}{% endblock %}

{% block body %}
    <div class="offline-container">
        <div class="offline-content">
            <!-- Icône Offline -->
            <div class="offline-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="120" height="120" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M9.172 9.172L5.636 5.636m3.536 9.192L5.636 18.364M12 12v.01M21 12a9 9 0 01-18 0 9 9 0 0118 0z" />
                </svg>
            </div>

            <h1>Vous êtes hors ligne</h1>
            <p class="offline-message">
                Impossible de se connecter à Internet.<br>
                Certaines fonctionnalités sont limitées.
            </p>

            <!-- Boutons d'action -->
            <div class="offline-actions">
                <button onclick="window.location.reload()" class="btn btn-primary">
                    <span>🔄</span> Réessayer
                </button>

                <button onclick="history.back()" class="btn btn-secondary">
                    Retour à la page précédente
                </button>
            </div>

            <!-- Informations supplémentaires -->
            <div class="offline-info">
                <small>Vous pouvez consulter les pages déjà visitées.</small>
            </div>
        </div>
    </div>
{% endblock %}

{% block stylesheets %}
    <style>
        .offline-container {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            background: linear-gradient(135deg, #f8fafc, #e2e8f0);
            font-family: system-ui, -apple-system, sans-serif;
            text-align: center;
            padding: 20px;
        }

        .offline-content {
            max-width: 420px;
        }

        .offline-icon {
            color: #64748b;
            margin-bottom: 2rem;
        }

        .offline-content h1 {
            font-size: 2.2rem;
            color: #1e2937;
            margin-bottom: 1rem;
        }

        .offline-message {
            color: #64748b;
            font-size: 1.1rem;
            line-height: 1.5;
            margin-bottom: 2.5rem;
        }

        .offline-actions {
            display: flex;
            gap: 12px;
            justify-content: center;
            flex-wrap: wrap;
            margin-bottom: 2rem;
        }

        .btn {
            padding: 14px 28px;
            border: none;
            border-radius: 12px;
            font-size: 1.05rem;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.2s;
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }

        .btn-primary {
            background: #2563eb;
            color: white;
        }

        .btn-primary:hover {
            background: #1d4ed8;
            transform: translateY(-2px);
        }

        .btn-secondary {
            background: #e2e8f0;
            color: #334155;
        }

        .btn-secondary:hover {
            background: #cbd5e1;
        }
    </style>
{% endblock %}
