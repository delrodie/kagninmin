{% extends 'base.html.twig' %}

{% block title %}Nos actualités{% endblock %}

{% block turbo_frame %}
    <turbo-frame id="main">
        {% block body %}
            <main>
                <section class="page-title cover-background">
                    <div class="container">
                        <div class="row align-items-center small-screen">
                            <div class="col-12 col-md-8">
                                <h4 class="fw-semibold color-gold animate__animated animate__slideInUp ">Galerie</h4>

                                <h1 class="animate__titre  fw-bold color-terra-dark">
                                    Albums photo
                                </h1>
                            </div>
                            <div class="col-md-4 d-none d-md-block">
                                <div class="animate__animated " data-animate="animate__zoomIn" data-parallax="0.3" data-duration="2.0s">
                                    <figure>
                                        <img src="{{ absolute_url(asset('images/autonomisation-circulaire.png')) }}" alt=""
                                             class="img-fluid">
                                    </figure>

                                </div>

                            </div>
                        </div>

                    </div>
                </section>

                <section class="actualites" id="actualites">
                    <div class="container animate__animated" data-animate="animate__slideInUp" data-duration="2.0s">

                        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4 mt-3">

                            {% for actualite in actualites %}
                            <div class="col">
                                <div class="card h-100 rounded-0 border-0 shadow">
                                    <figure class="overflow-hidden position-relative">
                                        <img src="{{ absolute_url(asset('uploads/actualites/' ~ actualite.media)) }}" alt="{{ actualite.titre }}" class="card-img-top" loading="lazy">
                                        <figcaption
                                            class="position-absolute text-end bottom-0 w-100 bg-text-black pe-1 py-2 actualite-figcaption">
                                            <small class="fw-semibold px-3 py-2">{{ actualite.photos|length }} photos</small>
                                        </figcaption>
                                    </figure>

                                    <div class="card-body pb-5">
                                        <h5 class="card-title">
                                            <a href="{{ absolute_url(path('app_galerie_details', {'slug': actualite.slug})) }}" class="text-decoration-none color-terra" data-turbo="false">{{ actualite.titre }}</a>
                                        </h5>
                                    </div>
                                </div>

                            </div>
                        {% endfor %}

                    </div>

                    </div>
                </section>



                <div {{ stimulus_controller('partenaire-loader',{ url: path('app_partenaire_list')}) }} style="margin-top: 100px;">
                    <div data-partenaire-loader-target="content">
                        <div class="text-center mt-5 p-5">
                            <div class="spinner-border text-primary" role="status">
                                <span class="visually-hidden">Chargement des partenaires...</span>
                            </div>
                        </div>
                    </div>
                </div>

            </main>
        {% endblock %}
    </turbo-frame>
{% endblock %}

