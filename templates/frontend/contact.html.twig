{% extends 'base.html.twig' %}

{% block turbo_frame %}
    <turbo-frame id="main">
        {% block body %}
            <main>
                <section class="page-title cover-background">
                    <div class="container">
                        <div class="row align-items-center small-screen">
                            <div class="col-12 col-md-8">
                                <h4 class="fw-semibold color-gold animate__animated animate__slideInUp ">Nous rejoindre</h4>

                                <h1 class="animate__titre  fw-bold color-terra-dark">
                                    Contactez-nous
                                </h1>
                            </div>
                            <div class="col-md-4 d-none d-md-block">
                                <div class="animate__animated " data-animate="animate__zoomIn" data-parallax="0.3" data-duration="2.0s">
                                    <figure>
                                        <img src="{{ absolute_url(asset('images/autonomisation-circulaire.png')) }}" alt=""
                                             class="img-fluid">
                                    </figure>

                                </div>

                            </div>
                        </div>

                    </div>
                </section>



                <section class="page margin-section" id="page">
                    <div class="container">
                        <div class="row row-cols-1 row-cols-lg-2 g-2 fw-400">
                            <div class="col">
                                <div class="card card-brown border-0 h-100">
                                    <div class="card-body">
                                        <h4 class="card-title fw-semibold color-terra-dark">Nos coordonnées</h4>

                                        {% if coordonnee %}

                                            <div class="row row-cols-1 g-4 mt-3">
                                                <div class="col d-flex align-items-center">
                                                    <div class="icon me-3">
                                                        <div class="card card-brown border-0">
                                                            <div class="card-body">
                                                                <i class="bi bi-geo-alt"></i>
                                                            </div>
                                                        </div>
                                                    </div>
                                                    <div class="infos">
                                                        <div class="color-terra-dark fw-semibold">Siège social</div>
                                                        <div class="donnees">{{ coordonnee.siege }}</div>
                                                    </div>
                                                </div>

                                                <div class="col d-flex align-items-center">
                                                    <div class="icon me-3">
                                                        <div class="card card-brown border-0">
                                                            <div class="card-body">
                                                                <i class="bi bi-envelope"></i>
                                                            </div>
                                                        </div>
                                                    </div>
                                                    <div class="infos">
                                                        <div class="color-terra-dark fw-semibold">Adresse email</div>
                                                        <div class="donnees">{{coordonnee.email}}</div>
                                                    </div>
                                                </div>
                                                <div class="col d-flex align-items-center">
                                                    <div class="icon me-3">
                                                        <div class="card card-brown border-0">
                                                            <div class="card-body">
                                                                <i class="bi bi-telephone"></i>
                                                            </div>
                                                        </div>
                                                    </div>
                                                    <div class="infos">
                                                        <div class="color-terra-dark fw-semibold">Téléphone</div>
                                                        <div class="donnees">
                                                            +225 {{ coordonnee.telephone}}
                                                            {{ coordonnee.phone1 ? " / " ~ coordonnee.phone1 : '' }}
                                                            {{ coordonnee.phone2 ? " / " ~ coordonnee.phone2 : '' }}
                                                        </div>
                                                    </div>
                                                </div>

                                                <div class="col d-flex align-items-center">
                                                    <div class="icon me-3">
                                                        <div class="card card-brown border-0">
                                                            <div class="card-body">
                                                                <i class="bi bi-clock"></i>
                                                            </div>
                                                        </div>
                                                    </div>
                                                    <div class="infos">
                                                        <div class="color-terra-dark fw-semibold">Horaires d'ouvertures</div>
                                                        <div class="donnees">{{ coordonnee.horaire }}</div>
                                                    </div>
                                                </div>

                                            </div>

                                        {% else %}
                                            <div class="fst-italic text-center">Aucune coordonnée</div>
                                        {% endif %}

                                    </div>
                                </div>
                            </div>

                            <!-- Formulaire -->
                            <div class="col">
                                <div class="card card-brown border-0 h-100">
                                    <div class="card-body p-5">
                                        <h4 class="card-title fw-semibold color-terra-dark">Nous écrire</h4>

                                        <form action="" class="contact">
                                            <div class="row form-group">
                                                <div class="mt-3">
                                                    <label for="nom" class="form-label">Nom & prénoms</label>
                                                    <input type="text" class="form-control">
                                                </div>
                                                <div class="mt-3">
                                                    <label for="email" class="form-label">Email</label>
                                                    <input type="email" class="form-control">
                                                </div>
                                                <div class="mt-3">
                                                    <label for="objet" class="form-">Objet</label>
                                                    <select name="" id="" class="form-select">
                                                        <option value="">-- Sélectionnez --</option>
                                                        {% for objet in objets %}
                                                            <option value="{{ objet.id }}">{{ objet.titre }}</option>
                                                        {% endfor %}
                                                    </select>

                                                </div>
                                                <div class="mt-3">
                                                    <label for="" class="form-label">Message</label>
                                                    <textarea name="" id="" cols="30" rows="5" class="form-control"></textarea>
                                                </div>
                                                <div class="mt-5 d-grid gap-2">
                                                    <button class="btn btn-terra rounded-0 btn-gd">Envoyer</button>
                                                </div>
                                            </div>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>




                <div {{ stimulus_controller('partenaire-loader',{ url: path('app_partenaire_list')}) }} style="margin-top: 100px;">
                    <div data-partenaire-loader-target="content">
                        <div class="text-center mt-5 p-5">
                            <div class="spinner-border text-primary" role="status">
                                <span class="visually-hidden">Chargement des partenaires...</span>
                            </div>
                        </div>
                    </div>
                </div>

            </main>
        {% endblock %}
    </turbo-frame>
{% endblock %}


{% block head %}
    <title>Contact - ONG KAGNINMIN</title>
    <meta name="description" content="L'ONG KAGNINMIN est une organisation ivoirienne engagée dans la valorisation du riche patrimoine culturel et touristique de la Côte d'Ivoire.">

    <meta property="og:title" content="Contact - ONG KAGNINMIN">
    <meta property="og:description" content="L'ONG KAGNINMIN est une organisation ivoirienne engagée dans la valorisation du riche patrimoine culturel et touristique de la Côte d'Ivoire.">
    <meta property="og:type" content="website">
    <meta property="og:url" content="{{ absolute_url(path('app_home')) }}">
    <meta property="og:image" content="{{ absolute_url(asset('images/logo.jpg')) }}">
{% endblock %}
