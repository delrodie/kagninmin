
<div class="row">
    <div class="col-md-12 col-lg-3">
        <div class="row justify-content-center align-items-center g-2">
            <div class="col-12 col-md-4 col-lg-12">
                <img src="{{ absolute_url(asset('uploads/apropos/' ~ presentation.media)) }}" alt="ONG KAGNINMIN" class="img-fluid logo">
            </div>
            <div class="col-12 col-md-8 col-lg-12 ms-auto">
                <div class="devise color-terra-light text-uppercase fw-semibold">
                    {{ presentation.tags }}
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4 col-lg-3 mt-5 mt-lg-0 apropos">
        <h6 class="title fw-semibold">{{ presentation.titre }}</h6>
        {{ presentation.contenu|striptags|raw }}
    </div>

    <div class="col-md-4 col-lg-3 mt-5 mt-lg-0 contact">
        <h6 class="title fw-semibold">Nous contacter</h6>
        <ul class="list">
            <li class="mb-1">
                <a href="#" class="link"><i class="bi bi-geo-alt me-1"></i>
                    {{ coordonnee.siege }}
                </a>
            </li>
            <li class="mb-1">
                <a href="mailto:{{ coordonnee.email }}" class="link">
                    <i class="bi bi-envelope me-1"></i>
                    {{ coordonnee.email }}
                </a>
            </li>
            <li class="d-flex flex-column">
                <a href="tel:+225{{ coordonnee.telephone }}" class="link"> <i class="bi bi-telephone"></i> +225 {{ coordonnee.telephone }}</a>
                <a href="tel:+225{{ coordonnee.phone1 }}" class="link"><i class="bi bi-phone"></i> +225 {{ coordonnee.phone1 }}</a>
                {% if coordonnee.phone2 %}
                    <a href="tel:+225{{ coordonnee.phone2 }}" class="link"> <i class="bi bi-phone"></i> +225 {{ coordonnee.phone2 }}</a>
                {% endif %}
                {% if coordonnee.phone3 %}
                    <a href="tel:+225{{ coordonnee.phone3 }}" class="link"> <i class="bi bi-phone"></i> +225 {{ coordonnee.phone3 }}</a>
                {% endif %}

            </li>
        </ul>

    </div>


    <div class="col-md-4 col-lg-3 mt-5 mt-lg-0">
        <h6 class="title fw-semibold">Nous suivre</h6>
        <div class="mt-3 justify-content-center align-items-center">
            <a href="{{ coordonnee.facebook ? coordonnee.facebook : "#" }}" class="icon link fs-2" target="_blank"><i class="bi bi-facebook"></i></a>
            <a href="{{ coordonnee.instagram ? coordonnee.instagram : "#" }}" class="icon link fs-2" target="_blank"><i class="bi bi-instagram"></i></a>
            <a href="https://wa.me/225{{ coordonnee.whatsapp }}" class="icon link fs-2" target="_blank"><i class="bi bi-whatsapp"></i></a>
        </div>
    </div>

</div>
